# ── FastAPI Backend Environment Variables ─────────────────────────────────────

# NeonDB (PostgreSQL) — Leave empty to use the in-memory influencer store
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=

# OpenRouter AI Gateway — Get a free key at https://openrouter.ai
# Used for brand-match explanations and campaign recommendations
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# RapidAPI — Optional, for live influencer data ingestion
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram-statistics-api.p.rapidapi.com

# Qdrant Vector Store — Optional, for semantic search
QDRANT_API_KEY=
QDRANT_URL=
