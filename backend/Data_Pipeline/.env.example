# ── 1. CORE RELATIONAL ENGINE (NeonDB Cluster) ──
NEON_DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/ratefluencer?sslmode=require

# ── 2. VECTOR ENCODING STORAGE LAYER (Qdrant Hub) ──
QDRANT_API_KEY=your_actual_qdrant_api_key_here
QDRANT_URL=https://your-qdrant-cluster-url.qdrant.io

# ── 3. INTERNAL PIPELINE TRACKING DIRECTORIES ──
DATA_PATH=/usr/local/airflow/include/data
MODEL_PATH=/usr/local/airflow/include/models

# ── 4. AGENTIC SUMMARY ENGINE (OpenRouter Gateway) ──
OPENROUTER_API_KEY=sk-or-v1-your-actual-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ── 5. SPECIFIC INFLUENCER DATA PROXIES (RapidAPI Provider) ──
# Points directly to a live creator metrics provider infrastructure
RAPIDAPI_KEY=your_real_rapidapi_key_here
RAPIDAPI_HOST=instagram-statistics-api.p.rapidapi.com